# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
shazza-*.tar

# Local data and audio fixtures used during development.
/data/
/priv/audio/

# Persistent indices — generated at runtime, never committed.
/priv/*.db
/priv/*.db-shm
/priv/*.db-wal
/priv/*.sqlite
/priv/*.sqlite-shm
/priv/*.sqlite-wal

# Compiled NIF artifacts — built per-platform from c_src/ via the
# Makefile, must not land in source control.
/priv/*.so
/priv/*.dylib
/priv/*.dll

# Editor / OS
.DS_Store
.elixir_ls/
.idea/
.vscode/
.mise.toml
mise.toml
.tool-versions

